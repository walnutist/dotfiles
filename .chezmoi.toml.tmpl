{{- $osid := .chezmoi.os -}}
{{- if eq .chezmoi.os "linux" -}}
  {{- if hasKey .chezmoi.osRelease "id" -}}
    {{- $osid = printf "%s-%s" .chezmoi.os .chezmoi.osRelease.id -}}
  {{- else -}}
    {{- $osid = printf "%s-unknown" .chezmoi.os -}}
  {{- end -}}
{{- end -}}
{{- $profiles := dict 
  "desktop" (dict "lscolors_theme" "tokyonight-night")
  "server-homelab" (dict "lscolors_theme" "lava")
  "vm-homelab" (dict "lscolors_theme" "catppuccin-latte")
  "lxc-homelab" (dict "lscolors_theme" "catppuccin-latte")
  "server-linode" (dict "lscolors_theme" "lava")
  "sandbox" (dict "lscolors_theme" "nord")
-}}
{{- $profile_keys := keys $profiles -}}
{{- $profile_choice := promptChoice "Profile for this machine?" $profile_keys -}}

[data]
osid = {{ $osid | quote }}
{{- range $key, $val := $profiles }}
[data.profiles.{{ $key }}]
  {{- range $k, $v := $val }}
  {{ $k }} = {{ $v | quote }}
  {{- end }}
{{- end }}

[data.local_profile]
name = {{ $profile_choice | quote }}
{{- range $key, $val := index $profiles $profile_choice }}
{{ $key }} = {{ $val | quote }}
{{- end }}

