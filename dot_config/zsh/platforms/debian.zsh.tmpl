# --- 阶段 2: 工具可用性检查 (fd / bat) ---
platform_prepare_env() {
    if command -v fdfind &>/dev/null; then
        alias fd='fdfind'
    fi
    if command -v batcat &>/dev/null; then
        alias bat='batcat'
    fi
}

platform_initialize() { :; }
platform_load_plugins() { :; }
platform_bind_keys() { :; }
platform_setup_options() { :; }
platform_setup_toolchains() { :; }
platform_setup_aliases() { :; }
platform_setup_functions() { :; }
platform_finalize() { :; }
