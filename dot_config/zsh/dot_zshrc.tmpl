# =============================================================================
# zshrc — 按阶段 (phase) 初始化
# =============================================================================
# 初始化顺序：phase_XXX → platform_XXX → profile_XXX
# 每个阶段按序执行，平台/Profile 脚本通过同名钩子注入自定义逻辑。
# 未实现钩子的脚本会被静默跳过（向后兼容）。

# =============================================================================
# 阶段函数定义
# =============================================================================

# --- 阶段 1: 初始化 z4h ---
# 配置 z4h 行为后执行 install 和 init，此后 z4h 插件系统可用。
phase_initialize() {
    zstyle ':z4h:' auto-update      'no'
    zstyle ':z4h:' auto-update-days '28'
    zstyle ':z4h:bindkey' keyboard  'mac'
    zstyle ':z4h:' start-tmux no
    zstyle ':z4h:' prompt-at-bottom 'no'
    zstyle ':z4h:' term-shell-integration 'yes'
    zstyle ':z4h:autosuggestions' forward-char 'accept'
    zstyle ':z4h:fzf-complete' recurse-dirs 'no'
    zstyle ':z4h:direnv'         enable 'yes'
    zstyle ':z4h:direnv:success' notify 'yes'
    zstyle ':z4h:ssh:*'                   enable 'no'
    # zstyle ':z4h:ssh:example-hostname1'   enable 'yes'
    # zstyle ':z4h:ssh:*.example-hostname2' enable 'no'
    # zstyle ':z4h:ssh:*' send-extra-files '~/.nanorc' '~/.env.zsh'

    z4h install ohmyzsh/ohmyzsh || return
    z4h init || return
}

# --- 阶段 2: 环境变量 & 镜像 ---
# 设置基础环境变量、语言、各工具链镜像源、dircolors/LS_COLORS。
phase_prepare_env() {
    # TTY & 语言
    export GPG_TTY=$TTY
    export LANG=en_US.UTF-8
    export LC_COLLATE=zh_CN.UTF-8

    # 各工具链镜像
    export RUSTUP_DIST_SERVER="https://mirrors.ustc.edu.cn/rust-static"
    export RUSTUP_UPDATE_ROOT="https://mirrors.ustc.edu.cn/rust-static/rustup"
    export UV_INDEX_URL="https://mirrors.ustc.edu.cn/pypi/simple"
    export PIP_TRUSTED_HOST="mirrors.ustc.edu.cn"
    export PIP_INDEX_URL="https://mirrors.ustc.edu.cn/pypi/simple"
    export GO111MODULE=on
    export GOPROXY="https://goproxy.cn,direct"
    export GOSUMDB="sum.golang.google.cn"
    export HF_ENDPOINT="https://hf-mirror.com"

    # dircolors / LS_COLORS 配置
    local preset="{{ .local_profile.dircolor_preset }}"
    if [[ -f "$HOME/.lscolors.theme-$preset" ]]; then
        export LS_COLORS="$(cat $HOME/.lscolors.theme-$preset)"
    elif [[ -f "$HOME/.dircolors.theme-$preset" ]]; then
        command -v dircolors &> /dev/null && eval "$(dircolors $HOME/.dircolors.theme-$preset)" || \
            export LS_COLORS="$(cat $HOME/.dircolors.theme-$preset | tr '\n' ':')"
    elif [[ -f "$HOME/.dircolors" ]]; then
        command -v dircolors &> /dev/null && eval "$(dircolors $HOME/.dircolors)" || \
            export LS_COLORS="$(cat $HOME/.dircolors | tr '\n' ':')"
    elif [[ "" != "$preset" ]] && command -v vivid &> /dev/null; then
        export LS_COLORS="$(vivid generate $preset)"
    fi
}

# --- 阶段 3: 加载 zsh 插件 ---
phase_load_plugins() {
    autoload -Uz zmv
    z4h load   ohmyzsh/ohmyzsh/plugins/sudo || true
    z4h load   ohmyzsh/ohmyzsh/plugins/extract || true
    z4h load   ohmyzsh/ohmyzsh/plugins/gitfast || true
    z4h load   ohmyzsh/ohmyzsh/plugins/rsync || true
    z4h load   ohmyzsh/ohmyzsh/plugins/cp || true
    z4h load   ohmyzsh/ohmyzsh/plugins/virtualenv || true
    z4h load   ohmyzsh/ohmyzsh/plugins/mise || true
    z4h load   ohmyzsh/ohmyzsh/plugins/chezmoi || true
    # z4h source   ohmyzsh/ohmyzsh/lib/directories.zsh
}

# --- 阶段 4: 绑定按键 ---
phase_bind_keys() {
    # Undo / Redo
    z4h bindkey undo            Ctrl+/          Shift+Tab    # undo the last command line change
    z4h bindkey redo            Alt+/           Option+/     # redo the last undone command line change

    # 目录导航 (Shift + 方向键)
    z4h bindkey z4h-cd-back     Alt+Left        Shift+Left   # cd 上一级目录
    z4h bindkey z4h-cd-forward  Alt+Right       Shift+Right  # cd 上一级目录
    z4h bindkey z4h-cd-up       Alt+Up          Shift+Up     # cd 父目录
    z4h bindkey z4h-cd-down     Alt+Down        Shift+Down   # cd 子目录

    # PC only?
    z4h bindkey z4h-backward-kill-word  Ctrl+Backspace     Ctrl+H
    z4h bindkey z4h-backward-kill-zword Ctrl+Alt+Backspace
}

# --- 阶段 5: shell 选项 & 历史 ---
phase_setup_options() {
    # 基础体验
    setopt glob_dots                # 通配符匹配隐藏文件
    setopt auto_cd                  # 输入目录名直接跳转
    setopt auto_menu                # 自动菜单补全
    setopt menu_complete            # 补全菜单中选择
    setopt no_beep                  # 禁止蜂鸣声
    setopt interactive_comments     # 交互模式下允许注释
    setopt no_nomatch               # 匹配失败不报错

    # 历史记录
    HISTSIZE=2000                   # 内存中保留的条数
    SAVEHIST=50000                  # 文件中保存的条数
    HISTFILE="${ZSH_CACHE_DIR:-$HOME}/.zsh_history"
    setopt extended_history         # 记录时间戳
    setopt share_history            # 多终端实时共享历史
    setopt hist_reduce_blanks       # 删除历史记录中的空行
    setopt hist_ignore_dups         # 忽略连续重复命令
    setopt hist_ignore_space        # 忽略空格开头的命令
    setopt hist_find_no_dups        # 搜索时不显示重复项
    unset command_not_found_handler   # 禁用 (响应速度太慢)
}

# --- 阶段 6: 工具链 ---
phase_setup_toolchains() {
    # 按需激活 mise 版本管理器。
    if command -v mise > /dev/null; then
        eval "$(mise activate zsh)"
    fi
}

# --- 阶段 7: 别名 ---
# 按用途分组：工具替换 → 快捷路径 → 危险操作 → git 操作
phase_setup_aliases() {
    # 工具替换 (更友好的替代品)
    command -v dust &> /dev/null && alias du="dust"                 # 磁盘占用
    command -v duf &> /dev/null && alias df="duf"                   # 磁盘挂载
    command -v btm &> /dev/null && alias top="btm"                  # 系统监控
    command -v gping &> /dev/null && alias ping="gping"             # 可视化 ping
    command -v delta &> /dev/null && alias diff="delta"             # git diff 美化
    command -v rg &> /dev/null && alias grep="rg"                   # 高速搜索
    command -v rg &> /dev/null && alias rgs="rg --smart-case"       # 智能大小写搜索
    command -v rg &> /dev/null && alias rgh="rg --hidden"           # 包含隐藏文件搜索
    command -v rg &> /dev/null && alias rgc="rg --color=always"     # 强制彩色输出
    command -v bat &> /dev/null && alias cat="bat"                  # bat 增强阅读
    command -v bat &> /dev/null && alias less="bat --paging=always"
    command -v lazygit &> /dev/null && alias gitui="lazygit"        # 交互式 git 终端
    command -v lazygit &> /dev/null && alias lg="lazygit"
    command -v eza &> /dev/null && alias ls="eza"                   # ls


    # 快捷路径 (.., ..., ...., .....)
    alias -g ...='../..'
    alias -g ....='../../..'
    alias -g .....='../../../..'
    alias -g ......='../../../../..'
    alias -- -='cd -'            # 回到上一个目录
    alias 1='cd -1'
    alias 2='cd -2'
    alias 3='cd -3'
    alias 4='cd -4'
    alias 5='cd -5'
    alias 6='cd -6'
    alias 7='cd -7'
    alias 8='cd -8'
    alias 9='cd -9'

    # 文件浏览
    alias ls="ls --group-directories-first"
    alias l='ls -lah'
    alias ll='ls -lh'
    alias path='echo $PATH | tr -s ":" "\n"'

    # 危险操作 (加 -i 确认)
    alias rm='rm -i'
    alias cp='cp -i'
    alias mv='mv -i'
    alias md='mkdir -p'
    alias rd='rmdir'

    # git 操作
    alias g='git'
    alias gs='git status -sb'
    alias ga='git add'
    alias gc='git commit'
    alias gp='git push'
    alias gl='git pull'
    alias gd='git diff'
    alias gco='git checkout'
}

# --- 阶段 8: 自定义函数 ---
phase_setup_functions() {
    # md: 创建目录并跳转 (带补全)
    function md() { [[ $# == 1 ]] && mkdir -p -- "$1" && cd -- "$1" }
    compdef _directories md

    # vf: fzf 文件快速打开
    vf() {
      local file=$(fd | fzf --preview 'bat --color=always {}')
      [[ -n "$file" ]] && vim "$file"
    }

    # cdf: fzf 切换目录
    cdf() {
      local dir=$(fd -t d | fzf --preview 'eza --tree -L1 --icons {}')
      [[ -n "$dir" ]] && cd "$dir"
    }

    # killf: fzf 交互式杀进程
    killf() {
      ps aux | fzf | awk '{print $2}' | xargs kill -9
    }

    # gb: fzf 交互式切换 git 分支
    gb() {
      git checkout $(git branch | fzf | sed 's/^* //')
    }
}

# --- 阶段 9: 收尾 ---
phase_finalize() {
    # 引入用户自定义 ~/.zshrc。
    [[ -f $HOME/.zshrc ]] && . $HOME/.zshrc
}

# =============================================================================
# 阶段执行器
# =============================================================================
# 先 source 脚本加载所有函数定义，再按阶段调用对应钩子。
# 脚本只含函数定义，source 多次无副作用。

# 加载 platform / profile 脚本（只定义函数，不执行）
[[ -r "${ZSH_CONFIG_DIR}/platforms/{{ .osid }}.zsh" ]] && source "${ZSH_CONFIG_DIR}/platforms/{{ .osid }}.zsh"
[[ -r "${ZSH_CONFIG_DIR}/profiles/{{ .local_profile }}.zsh" ]] && source "${ZSH_CONFIG_DIR}/profiles/{{ .local_profile }}.zsh"

# 按阶段执行：主 phase → platform 钩子 → profile 钩子
__phase_hook() {
    local phase="$1"
    local func_name="${2}_${phase}"
    if typeset -f "$func_name" >/dev/null 2>&1; then
        "$func_name"
    fi
}

for _current in initialize prepare_env load_plugins bind_keys setup_options setup_toolchains setup_aliases setup_functions finalize; do
    phase_"$_current"
    __phase_hook "platform" "$_current"
    __phase_hook "profile" "$_current"
done
unset _current
